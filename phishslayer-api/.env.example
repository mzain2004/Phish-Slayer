# FILE: phishslayer-api/.env.example
# Environment variables for PhishSlayer Python FastAPI backend

# API Configuration
PORT=8000
HOST=0.0.0.0
ENV=development
CORS_ORIGINS=http://localhost:3000

# Python Backend URL (used by Next.js to proxy requests)
PYTHON_API_URL=http://localhost:8000

# Database
MONGODB_URI=mongodb://localhost:27017/phishslayer

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Third-party APIs
AGENTOPS_API_KEY=your-agentops-api-key
GROQ_API_KEY=your-groq-api-key
POLAR_WEBHOOK_SECRET=your-polar-webhook-secret

# Cron Jobs
CRON_SECRET=your-cron-secret-key

# Wazuh Integration
WAZUH_API_URL=https://wazuh-manager.example.com:55000
WAZUH_API_USER=admin
WAZUH_API_PASSWORD=your-wazuh-password

# Ollama Integration
OLLAMA_API_URL=http://localhost:11434

# Email Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password

# Logging
LOG_LEVEL=INFO
